<Window x:Class="TinyIcon.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:beh="clr-namespace:TinyIcon.Behaviors"
        xmlns:vm="clr-namespace:TinyIcon.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=False}"
        SnapsToDevicePixels="True" UseLayoutRounding="True"
        Title="TinyIcon" Height="600" Width="900">

    <!-- The gestures shown via InputGestureText in the menu below. -->
    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="N" Command="{Binding NewIconCommand}" />
        <KeyBinding Modifiers="Control" Key="I" Command="{Binding ImportImageCommand}" />
        <KeyBinding Modifiers="Control" Key="S" Command="{Binding SaveIconCommand}" />
        <KeyBinding Modifiers="Control" Key="Add" Command="{Binding ZoomInCommand}" />
        <KeyBinding Modifiers="Control" Key="OemPlus" Command="{Binding ZoomInCommand}" />
        <KeyBinding Modifiers="Control" Key="Subtract" Command="{Binding ZoomOutCommand}" />
        <KeyBinding Modifiers="Control" Key="OemMinus" Command="{Binding ZoomOutCommand}" />
        <KeyBinding Modifiers="Control" Key="Multiply" Command="{Binding ZoomResetCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <!-- Checkerboard backdrop so transparency is visible behind previews and the detail view. -->
        <DrawingBrush x:Key="Checkerboard" TileMode="Tile" Stretch="None"
                      Viewport="0,0,16,16" ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="White">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,16,16" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#FFCCCCCC">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,8,8" />
                                <RectangleGeometry Rect="8,8,8,8" />
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </Window.Resources>

    <DockPanel>
        <!-- Menu -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New Icon…" Command="{Binding NewIconCommand}" InputGestureText="Ctrl+N">
                    <MenuItem.Icon>
                        <Image Source="/Resources/NewIcon.png" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Import Image…" Command="{Binding ImportImageCommand}" InputGestureText="Ctrl+I">
                    <MenuItem.Icon>
                        <Image Source="/Resources/ImportImage.png" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Save Icon…" Command="{Binding SaveIconCommand}" InputGestureText="Ctrl+S">
                    <MenuItem.Icon>
                        <Image Source="/Resources/SaveIcon.png" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="E_xit" Click="Exit_Click" />
            </MenuItem>

            <MenuItem Header="_View">
                <MenuItem Header="Zoom _In" Command="{Binding ZoomInCommand}" InputGestureText="Ctrl++">
                    <MenuItem.Icon>
                        <Image Source="/Resources/ZoomIn.png" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Zoom _Out" Command="{Binding ZoomOutCommand}" InputGestureText="Ctrl+-">
                    <MenuItem.Icon>
                        <Image Source="/Resources/ZoomOut.png" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Zoom _Reset" Command="{Binding ZoomResetCommand}" InputGestureText="Ctrl+*">
                    <MenuItem.Icon>
                        <Image Source="/Resources/ZoomReset.png" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="?">
                <MenuItem Header="_About" Command="{Binding AboutCommand}" />
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar Height="32">
                <Button Command="{Binding NewIconCommand}" ToolTip="New Icon (Ctrl+N)"
                        AutomationProperties.Name="New Icon">
                    <Image Source="/Resources/NewIcon.png" />
                </Button>
                <Button Command="{Binding ImportImageCommand}" ToolTip="Import Image (Ctrl+I)"
                        AutomationProperties.Name="Import Image">
                    <Image Source="/Resources/ImportImage.png" />
                </Button>
                <Button Command="{Binding SaveIconCommand}" ToolTip="Save Icon (Ctrl+S)"
                        AutomationProperties.Name="Save Icon">
                    <Image Source="/Resources/SaveIcon.png" />
                </Button>
                <Separator />
                <Button Command="{Binding ZoomInCommand}" ToolTip="Zoom In (Ctrl++)"
                        AutomationProperties.Name="Zoom In">
                    <Image Source="/Resources/ZoomIn.png" />
                </Button>
                <Button Command="{Binding ZoomOutCommand}" ToolTip="Zoom Out (Ctrl+-)"
                        AutomationProperties.Name="Zoom Out">
                    <Image Source="/Resources/ZoomOut.png" />
                </Button>
                <Button Command="{Binding ZoomResetCommand}" ToolTip="Reset Zoom (Ctrl+*)"
                        AutomationProperties.Name="Reset Zoom">
                    <Image Source="/Resources/ZoomReset.png" />
                </Button>
                <Separator />
                <TextBlock VerticalAlignment="Center" Margin="4,0" MinWidth="44"
                           Text="{Binding ZoomLevel, StringFormat={}{0:P0}}" />
            </ToolBar>
        </ToolBarTray>

        <!-- Split content -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="160" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="200" />
            </Grid.ColumnDefinitions>

            <!-- Left: sub-image previews at native resolution -->
            <ListBox Grid.Column="0" Background="#FFF4F4F4"
                     ItemsSource="{Binding SubImages}" SelectedItem="{Binding SelectedSubImage}"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4,6">
                            <Border HorizontalAlignment="Center" BorderBrush="#FF888888" BorderThickness="1"
                                    Background="{StaticResource Checkerboard}"
                                    Width="{Binding Width}" Height="{Binding Height}">
                                <Image Source="{Binding Bitmap}" Stretch="None"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor" />
                            </Border>
                            <TextBlock Text="{Binding Label}" HorizontalAlignment="Center" Margin="0,4,0,0" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <GridSplitter Grid.Column="1" Width="5" VerticalAlignment="Stretch" HorizontalAlignment="Center"
                          Background="#FFD0D0D0" />

            <!-- Right: centered, zoomable, right-drag pannable detail view -->
            <Grid Grid.Column="2" Background="#FF3F3F46">
                <!-- Clipping host: a Canvas measures its child with an infinite constraint, so the Border reports
                     its true (zoomed) size even when larger than the panel; the image is moved with a
                     RenderTransform, so it must be clipped to this panel. -->
                <Canvas ClipToBounds="True">
                    <Canvas.Style>
                        <Style TargetType="Canvas">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSubImage.Bitmap}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Canvas.Style>
                    <!-- At Canvas (0,0): PanBehavior owns centering so a zoomed, oversized image stays centered. -->
                    <Border BorderBrush="Black" BorderThickness="1"
                            Background="{StaticResource Checkerboard}">
                        <b:Interaction.Behaviors>
                            <!-- Recenter when the selected sub-image changes. -->
                            <beh:PanBehavior MinVisibleFraction="0.25" ResetSignal="{Binding SelectedSubImage}" />
                        </b:Interaction.Behaviors>
                        <Image Source="{Binding SelectedSubImage.Bitmap}" Stretch="None"
                               RenderOptions.BitmapScalingMode="NearestNeighbor">
                            <b:Interaction.Behaviors>
                                <beh:ZoomBehavior ZoomLevel="{Binding ZoomLevel}" MinZoom="0.1" MaxZoom="16" />
                            </b:Interaction.Behaviors>
                        </Image>
                    </Border>
                </Canvas>

                <TextBlock Foreground="#FFDDDDDD" HorizontalAlignment="Center" VerticalAlignment="Center"
                           TextAlignment="Center" TextWrapping="Wrap" MaxWidth="300"
                           Text="Create a new icon (File ▸ New Icon), select a sub-image, then import an image to preview it here.">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSubImage.Bitmap}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
